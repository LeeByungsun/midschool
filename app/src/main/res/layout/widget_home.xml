<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widgetContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        
        <TextView
            android:id="@+id/widgetDateText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/brand_navy"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="🗓️ 오늘 (MM/DD)" />

        <ImageView
            android:id="@+id/widgetSettingsButton"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/widget_open_settings"
            android:src="@android:drawable/ic_menu_manage" />

        <ImageView
            android:id="@+id/widgetRefreshButton"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/widget_refresh"
            android:src="@drawable/ic_refresh" />
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="#D6DFEA" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">
        
        <LinearLayout
            android:id="@+id/widgetTodaySection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_today_label"
                android:textSize="12sp"
                android:textColor="@color/brand_blue"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widgetTimetableText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="8"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                tools:text="1교시: 국어\n2교시: 수학" />
        </LinearLayout>
        
        <ImageView
            android:id="@+id/widgetTimetableDivider"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#D6DFEA"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp" />

        <LinearLayout
            android:id="@+id/widgetTomorrowSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_tomorrow_label"
                android:textSize="12sp"
                android:textColor="@color/brand_blue"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widgetTomorrowTimetableText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="8"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                tools:text="불러오는 중..." />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
